# ════════════════════════════════════
# SafeInvest AI — 루트 .gitignore
# ════════════════════════════════════

# ── 환경변수 (절대 커밋 금지) ──────────────
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# ── Python ──────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ── Node.js ─────────────────────────────
node_modules/
frontend/dist/
frontend/dist-ssr/

# ── 테스트 캐시 ─────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE ─────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 로그 ────────────────────────────────
*.log
logs/

# ── 대용량 데이터 파일 (커밋 금지) ────────────────
*.sqlite
*.db

# ── 도구 자동 생성 폴더 ─────────────────────────
.claude/
