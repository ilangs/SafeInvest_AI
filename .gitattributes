# SafeInvest AI — .gitattributes
# Windows/Mac 팀 공용 줄바꿈 통일

* text=auto eol=lf

# Python
*.py    text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.env   text eol=lf

# JavaScript / React
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# 바이너리 (변환 금지)
*.png   binary
*.jpg   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
