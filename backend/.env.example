# ============================================================
# SafeInvest AI — Backend 환경변수 템플릿
# ============================================================
# 사용 방법:
#   1. 이 파일을 .env 로 복사합니다: cp .env.example .env
#   2. 실제 값을 채워넣습니다.
#   3. .env 는 절대 git 에 커밋하지 마세요 (.gitignore 확인)
#
# 키 이름을 임의로 변경하지 마세요 — 팀 전원이 동일한 이름을 사용합니다.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
# Supabase Dashboard → Project Settings → API Keys → Legacy anon keys
SSUPABASE_ANON_KEY="eyJhbGci..."
# Supabase Dashboard → Project Settings → JWT Keys → Legacy JWT Secret
SUPABASE_JWT_SECRET="sJk...TnVA=="

# ── OpenAI ───────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ── KIS API (한국투자증권 KIS Developers) ────────────────────
# https://apiportal.koreainvestment.com → 앱 등록 후 발급
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
# 모의투자 계좌번호 (8자리-2자리 형식, 예: 50123456-01)
KIS_ACCOUNT_NO=00000000
# true=모의투자(기본값, 개발 중 항상 true 유지), false=실거래
KIS_IS_MOCK=true
