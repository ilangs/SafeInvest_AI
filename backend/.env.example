# ============================================================
# SafeInvest AI — Backend 환경변수 템플릿
# ============================================================
# 사용 방법:
#   1. 이 파일을 .env 로 복사합니다: cp .env.example .env
#   2. 실제 값을 채워넣습니다.
#   3. .env 는 절대 git 에 커밋하지 마세요 (.gitignore 확인)
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY="eyJhbGci..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."
# Supabase Dashboard → Project Settings → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET="your-jwt-secret=="

# ── FastAPI ───────────────────────────────────────────────────
FASTAPI_ENV="development"
# 생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
FASTAPI_SECRET_KEY="change-me-in-production-use-secrets-token-hex-32"

# ── CORS (콤마로 구분, 공백 없이) ────────────────────────────
# 로컬: http://localhost:5173
# 운영: https://your-app.vercel.app (Render Dashboard 환경변수에 입력)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176"

# ── 암호화 키 (사용자 KIS 자격증명 AES-256 암호화) ─────────────
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="your-fernet-key-here="

# ── OpenAI ───────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ── DART OpenAPI (재무제표 수집용 — analysis/daily_update.py) ──
DART_API_KEY="your-dart-api-key-here="

# ── LangChain (선택, 모니터링용) ──────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY="ls-..."
